{$DOMAIN} {
    file_server /static*
    @options {
        method OPTIONS
    }

    handle @options {
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
            Access-Control-Allow-Headers *
        }
        respond "" 204
    }
    route {
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
            Access-Control-Allow-Headers *
        }
        handle_path /app/label-studio* {
            reverse_proxy localhost:8080
        }
        reverse_proxy /app/mlflow* localhost:8081
        reverse_proxy /infer* localhost:9090
        reverse_proxy localhost:8079
    }
}
{$DOMAIN_PUBLIC} {
    file_server /static*
    reverse_proxy /infer* localhost:9090
}
